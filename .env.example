# SokaSafari Travel — environment variables
# Copy to .env.local for local dev. Set these in Netlify → Site configuration → Environment variables.
# The app runs entirely on in-memory seed data without any of these.

# ── Admin auth ───────────────────────────────────────────────────────────────
# ADMIN_SESSION_SECRET must be a long random string (e.g. openssl rand -hex 32)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ── Provider portals (optional) ───────────────────────────────────────────────
FLIGHT_EMAIL=
FLIGHT_PASSWORD=
BUS_EMAIL=
BUS_PASSWORD=

# ── Supabase (optional — enables persistent DB storage) ──────────────────────
# Self-hosted: NEXT_PUBLIC_SUPABASE_URL=http://<droplet-ip>:8000
# Supabase cloud: NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site metadata ─────────────────────────────────────────────────────────────
# Set to your Netlify deploy URL or custom domain
NEXT_PUBLIC_SITE_URL=
